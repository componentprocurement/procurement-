# ----------------------------------------------------------------------------
# Template for Streamlit secrets. DO NOT put real keys in this file.
#
# Local dev:  copy this to  .streamlit/secrets.toml  and fill it in.
# Cloud:      paste the same content into  Streamlit Cloud → Manage app →
#             Settings → Secrets  (do NOT commit the real secrets.toml).
#
# When these secrets are present, the app stores data in the shared Google
# Sheet. When they are absent, it falls back to the local wishlist.xlsx file.
# ----------------------------------------------------------------------------

# The Google Sheet to use. Provide ONE of the two (key is easiest):
spreadsheet_key = "PASTE_THE_LONG_ID_FROM_THE_SHEET_URL"
# spreadsheet_url = "https://docs.google.com/spreadsheets/d/XXXX/edit"

# Paste the entire downloaded service-account JSON here, field by field.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR\nKEY\nHERE\n-----END PRIVATE KEY-----\n"
client_email = "procurement-bot@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/procurement-bot%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
